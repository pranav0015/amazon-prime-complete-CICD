// This is the infrastructure Pipeline.

pipeline{
    agent any

    environment{
        KUBECTL= '/usr/local/bin'
    }

    parameters{
        string(name: 'EKS_Cluster_Name', defaultValue: 'amazon-prime-cluster', description: 'Enter the EKS Cluster Name')
    }


    stages{
        stage("Login to EKS"){
            steps{
                script{
                     withCredentials([string(credentialsId: 'iam-user-access-key', variable: 'AWS_ACCESS_KEY'), string(credentialsId: 'iam-user-secret-key', variable: 'AWS_SECRET_KEY')]) {
                        sh "aws eks update-kubeconfig --region ap-south-1 --name ${params.EKS_Cluster_Name}"
                     }
                }
            }
        }

        stage("Configure Promehteus & Grafana"){
            steps{
                script{
                    sh """
                    helm repo add stable https://charts.helm.sh/stable || true
                    helm repo add prometheus-community https://prometheus-community.github.io/helm-charts || true
                    helm repo update

                    # check if "prometheus" namespace exists
                    if kubectl get namespace prometheus > /dev/null 2>&1; then
                        # if exists, upgrade the HELM relase
                        helm upgrade --install stable prometheus-community/kube-prometheus-stack -n prometheus
                    else
                        # if not exists, create it and install HELM release
                        kubectl create namespace prometheus
                        helm install stable prometheus-community/kube-prometheus-stack -n prometheus
                    fi

                    kubectl get svc -n prometheus
                    kubectl patch svc stable-kube-prometheus-sta-prometheus -n prometheus -p '{"spec": {"type": "LoadBalancer"}}'
                    kubectl patch svc stable-grafana -n prometheus -p '{"spec": {"type": "LoadBalancer"}}'

                    """
                }
            }
        }

        stage("Configure ArgoCD"){
                steps{
                    script{
                        sh """
                        # install ArgoCD
                        kubectl create namespace argocd || true
                        kubectl apply -n argocd -f https://raw.githubusercontent.com/argoproj/argo-cd/v2.11.3/manifests/install.yaml
                        kubectl get svc -n argocd
                        kubectl patch svc argocd-server -n argocd -p '{"spec": {"type": "LoadBalancer"}}'
                       
                        """
                    }
                }
        }
    }
}