// This is the deployment Pipeline (CD) using ArgoCD.

pipeline{
    agent any

    parameters{
        string(name: 'Image_Tag', defaultValue: 'latest', description: 'Docker Image Tag')
    }


    stages{

        stage('Git Checkout') {
            steps {
                git branch: 'main', credentialsId: 'github-cred', url: 'https://github.com/pranav0015/amazon-prime-complete-CICD.git'
            }
        }

        stage("Updated Kubernetes Manifesh and Push to Github"){
            steps{
                script{
                    sh """
                    # replace the docker image tag with the latest build number and updated the deployment file

                    sed -i "s|amazon-prime:.*|amazon-prime:${params.Image_Tag}|g" "./k8's files/deployment-service.yaml"
                    cat "./k8's files/deployment-service.yaml"

                    # Once deployment files updated, push the changes to Github, so that ArgoCD can detect the change automatically & can syncs automatically. 

                    git add "./k8's files/deployment-service.yaml"

                    git commit -m "Updated image tag to ${params.Image_Tag}" || echo "nothing to commit"

                    """

                    withCredentials([gitUsernamePassword(credentialsId: 'github-cred', gitToolName: 'Default')]) {
                        sh """
                        git push https://github.com/pranav0015/amazon-prime-complete-CICD.git HEAD:main
                        """
                     }
                     
                }
            }
        }
    }
}